{
  "name": "delta-terminal",
  "version": "0.5.0",
  "description": "AGORA Terminal",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac"
  },
  "build": {
    "appId": "com.agora.terminal",
    "productName": "Delta Terminal",
    "mac": {
      "category": "public.app-category.finance",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "icon": "icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "contents": [
        { "x": 140, "y": 180, "type": "file" },
        { "x": 400, "y": 180, "type": "link", "path": "/Applications" }
      ]
    },
    "files": ["main.js", "package.json", "icon.png", "icon.icns", "node_modules/**/*"],
    "extraResources": [{
      "from": "..",
      "to": "bloomberg",
      "filter": ["**/*", "!**/__pycache__/**", "!**/*.pyc", "!**/.git/**", "!delta-terminal-app/**", "!prototyping/**"]
    }]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  }
}
